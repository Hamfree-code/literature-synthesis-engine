# Literature Synthesis Engine — environment template
# Copy this file to `.env` at the project root and fill in your own credentials.
# Variable names derived from `config/settings.py` (pydantic-settings BaseSettings).
# Defaults in code apply when a variable is omitted here.

# ──────────────────────────────────────────────────────────────────────────────
# Anthropic API (required)
# Get a key at https://console.anthropic.com/
# ──────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
# Arbiter (reconciles the two reviewers). Opus by default — strongest neutral
# adjudicator. Set to claude-sonnet-4-6 to revert to the v3.1 behaviour.
ANTHROPIC_ARBITER_MODEL=claude-opus-4-8

# Reviewer B provider: "anthropic" (Sonnet) or "gemini" (Gemini Flash, for
# cross-model diversity). "gemini" needs GEMINI_API_KEY + `pip install -e .[gemini]`;
# without them it falls back to the Anthropic reviewer automatically.
REVIEWER_B_PROVIDER=anthropic
# Google Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────────────────────
# NCBI E-utilities (required for PMC ingestion)
# Free key at https://www.ncbi.nlm.nih.gov/account/ — increases rate limit
# from 3 req/s to 10 req/s.
# ──────────────────────────────────────────────────────────────────────────────
NCBI_API_KEY=REPLACE_ME
NCBI_EMAIL=you@example.com

# ──────────────────────────────────────────────────────────────────────────────
# Supabase (required for persistence; pgvector extension must be enabled)
# Use the service_role key only on a private backend — never ship in a client.
# ──────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=sb_secret_REPLACE_ME

# ──────────────────────────────────────────────────────────────────────────────
# Pipeline limits (defaults shown — override if you want)
# ──────────────────────────────────────────────────────────────────────────────
MAX_PAPERS=5000
MAX_DEEP_ANALYSIS=500
BATCH_SIZE=100
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# v3 toggles (defaults shown)
# ARBITER_ENABLED=True triples Sonnet deep-extraction cost — two reviewers
# (temp 0.1 and 0.3) + an arbiter (temp 0.0). Set to False for single-pass.
# ──────────────────────────────────────────────────────────────────────────────
# ARBITER_ENABLED=True
# UMLS_NORMALIZATION_ENABLED=True

# ── v3.1 optional services (all free; the engine degrades gracefully without) ──
# UMLS REST verification of CUIs (P2). Get a free UTS key:
#   https://uts.nlm.nih.gov/uts/signup-login  (Profile → Generate API Key)
UMLS_API_KEY=
# OpenAlex polite-pool contact (P4); falls back to NCBI_EMAIL if blank.
OPENALEX_MAILTO=
# Unpaywall requires an email (P4); falls back to NCBI_EMAIL if blank.
UNPAYWALL_EMAIL=
# Feature flags (defaults shown). Override only to change behaviour.
# EXTRACTION_TOOL_USE=true        # forced tool-use deep extraction (P1)
# INCLUDE_RETRACTED=false         # keep retracted papers out by default (P2)
# STATS_REFERENCE_IMPL=true       # PyMARE/statsmodels estimators (P3)
# OPENALEX_ENABLED=true           # multi-source discovery (P4)
# MEDRXIV_LEGACY=false            # re-enable the slow client-side medRxiv scan
# UNPAYWALL_ENABLED=true          # OA full-text fallback (P4)
