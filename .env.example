# Literature Synthesis Engine — environment template
# Copy this file to `.env` at the project root and fill in your own credentials.
# Variable names derived from `config/settings.py` (pydantic-settings BaseSettings).
# Defaults in code apply when a variable is omitted here.

# ──────────────────────────────────────────────────────────────────────────────
# Anthropic API (required — deep-extraction Reviewer A + arbiter)
# Get a key at https://console.anthropic.com/
# ──────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_OPUS_MODEL=claude-opus-4-8

# ──────────────────────────────────────────────────────────────────────────────
# Google Gemini (required — triage filter + deep-extraction Reviewer B)
# Get a key at https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_ME
GEMINI_FLASH_MODEL=gemini-3.5-flash
GEMINI_PRO_MODEL=gemini-3.1-pro
GEMINI_CONCURRENCY=8

# ──────────────────────────────────────────────────────────────────────────────
# NCBI E-utilities (required for PMC ingestion)
# Free key at https://www.ncbi.nlm.nih.gov/account/ — increases rate limit
# from 3 req/s to 10 req/s.
# ──────────────────────────────────────────────────────────────────────────────
NCBI_API_KEY=REPLACE_ME
NCBI_EMAIL=you@example.com

# ──────────────────────────────────────────────────────────────────────────────
# OpenAlex (third ingestion source — free key recommended)
# Free key at https://openalex.org/ — 100 credits/day without one (since
# 2026-02-13). OPENALEX_MAILTO falls back to NCBI_EMAIL if left blank.
# ──────────────────────────────────────────────────────────────────────────────
OPENALEX_API_KEY=REPLACE_ME
OPENALEX_MAILTO=you@example.com
OPENALEX_ENABLED=True

# ──────────────────────────────────────────────────────────────────────────────
# Supabase (required for persistence; pgvector extension must be enabled)
# Use the service_role key only on a private backend — never ship in a client.
# ──────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=sb_secret_REPLACE_ME

# ──────────────────────────────────────────────────────────────────────────────
# Pipeline limits (defaults shown — override if you want)
# ──────────────────────────────────────────────────────────────────────────────
MAX_PAPERS=5000
MAX_DEEP_ANALYSIS=500
BATCH_SIZE=100
LOG_LEVEL=INFO

# Cost guardrails: the pipeline aborts before submitting any paid batch if the
# up-front estimate exceeds MAX_SPEND_USD (set 0 to disable). BATCH_MAX_POLL_HOURS
# bounds how long a single Batch API job is polled before giving up (the id is
# persisted, so a later run resumes rather than resubmits).
MAX_SPEND_USD=25.0
BATCH_MAX_POLL_HOURS=26.0

# ──────────────────────────────────────────────────────────────────────────────
# v3 toggles (defaults shown)
# ARBITER_ENABLED=True triples Sonnet deep-extraction cost — two reviewers
# (temp 0.1 and 0.3) + an arbiter (temp 0.0). Set to False for single-pass.
# ──────────────────────────────────────────────────────────────────────────────
# ARBITER_ENABLED=True
# UMLS_NORMALIZATION_ENABLED=True
